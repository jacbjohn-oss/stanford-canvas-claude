# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Get this from: canvas.stanford.edu → Account → Settings → New Access Token
# When copying the token, copy it all in one go — the UI wraps long tokens
# across lines but the hyphen at the end of a line is NOT part of the token.
CANVAS_API_TOKEN=your_token_here

CANVAS_BASE_URL=https://canvas.stanford.edu
